{
  "name": "vuepress-theme-hope-root",
  "private": true,
  "description": "A VuePress theme with tons of features",
  "workspaces": [
    "demo/*",
    "docs/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm run --stream -r build",
    "bundle": "cross-env NODE_ENV=production pnpm run --stream -r build",
    "clean": "pnpm run --stream -r clean",
    "dev": "pnpm run --parallel -r dev",
    "docs:vite-build": "pnpm run -r docs:vite-build",
    "docs:webpack-build": "pnpm run -r docs:webpack-build",
    "lint": "oxfmt . & pnpm lint:stylelint --fix && pnpm lint:oxlint --fix",
    "lint:check": "oxfmt --check . && pnpm lint:stylelint && pnpm lint:oxlint",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:oxlint": "oxlint --report-unused-disable-directives --deny-warnings",
    "lint:stylelint": "stylelint \"**/*.{css,scss}\" \"**/.vuepress/**/*.{css,scss}\"",
    "pkg:check-update": "pnpm dlx npm-check-updates",
    "pkg:update": "pnpm up -r",
    "prepare": "husky",
    "release": "pnpm clean && pnpm bundle && pnpm release:version && pnpm release:publish && pnpm release:sync",
    "release:publish": "lerna publish from-package --yes",
    "release:sync": "cross-env NODE_OPTIONS=\"--experimental-json-modules\" unrun scripts/sync.ts",
    "release:version": "lerna version",
    "test": "vitest --coverage"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@lerna-lite/cli": "5.0.0",
    "@lerna-lite/publish": "5.0.0",
    "@mr-hope/tsconfig": "0.0.3",
    "@types/node": "20.19.37",
    "@types/webpack-env": "1.18.8",
    "@vitejs/devtools": "0.1.11",
    "@vitest/coverage-istanbul": "4.1.2",
    "concurrently": "9.2.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cross-env": "10.1.0",
    "husky": "9.1.7",
    "markdownlint-cli2": "0.22.0",
    "nano-staged": "0.9.0",
    "oxc-config-hope": "0.1.6",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.19.0",
    "publint": "0.3.18",
    "rimraf": "6.1.3",
    "serve": "^14.2.6",
    "stylelint": "17.6.0",
    "stylelint-config-hope": "11.0.0",
    "through2": "4.0.2",
    "tsdown": "0.21.7",
    "typescript": "6.0.2",
    "unrun": "0.2.34",
    "vite": "8.0.3",
    "vite-plugin-inspect": "12.0.0-beta.1",
    "vitest": "4.1.2",
    "vuepress": "catalog:vuepress"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.vue": "oxlint --fix",
    "*.{cjs,mjs,js,ts}": [
      "oxlint --fix",
      "vitest related --run"
    ],
    "*.md": "markdownlint-cli2 --fix",
    "*.s?css": "stylelint --fix"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || ^24"
  },
  "packageManager": "pnpm@10.33.0"
}
